# SpriteForge 環境変数テンプレート
# このファイルをコピーして .env にリネームし、各自の環境に合わせて編集する
# .env は .gitignore に含まれているためコミットされない

# Godot プロジェクトのアセットフォルダへの絶対パス
# config/settings.json の godot_export_path と同じ値を設定する
SF_GODOT_EXPORT_PATH=C:/godot-project/assets/prototype/buildings

# バックエンドが起動するポート（デフォルト: 8000）
SF_BACKEND_PORT=8000

# フロントエンドが参照する API ベース URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
