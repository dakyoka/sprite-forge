# SpriteForge 環境変数テンプレート
# このファイルをコピーして .env にリネームします（.env は .gitignore 済み）。
#
# 重要: バックエンドの設定の正本(SSOT)は config/settings.json です。
#   - Godot 書き出し先   -> config/settings.json -> godot_export_path
#   - TRELLIS の場所      -> config/settings.json -> trellis_path
#   - Blender 実行ファイル -> config/settings.json -> blender_exe
# これらは setup.ps1 のパラメータ(-GodotExportPath / -TrellisPath / -BlenderExe)
# でも設定でき、settings.json に書き込まれます。.env には書かないでください。

# フロントエンドが参照する API ベース URL。
# 通常は setup.ps1 が frontend/.env.local を自動生成するため、ここでの設定は不要です。
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
