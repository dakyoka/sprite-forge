{
  "godot_export_path": "C:/godot-project/assets/prototype/buildings",
  "trellis_path": "H:/TRELLIS",
  "trellis_model": "microsoft/TRELLIS-image-large",

  "gpu_preset": "auto",
  "_comment_fp16": "fp16 はサンプリング段のみ fp16 autocast を適用する意味 (decode は fp32 のまま)。全モデルの half 化ではない。",
  "_comment_low_quality": "low(8GB)の品質上限は trellis_steps=6。steps=4 だと SLAT が収束不足でメッシュが断片化し穴が増える(boundary loops 19/開放エッジ89/浮き断片45)。steps=6 でほぼ解消(穴3/開放エッジ7/断片6)し、decode_slat も 8GB に収まり約2分で完了する。steps>=12 は decode_slat(fp32 flexicubes)が 8GB を超えて共有メモリへスピルし数十分かかる/事実上 OOM。texture_size>512 や bake_mode='opt' も 8GB では避ける。より大きな GPU では standard/high プリセットでさらに高品質化できる。",
  "gpu_presets": {
    "low": {
      "max_vram_gb": 10,
      "trellis_steps": 6,
      "texture_size": 512,
      "bake_mode": "fast",
      "fp16": true
    },
    "standard": {
      "max_vram_gb": 16,
      "trellis_steps": 12,
      "texture_size": 1024,
      "bake_mode": "fast",
      "fp16": true
    },
    "high": {
      "max_vram_gb": null,
      "trellis_steps": 25,
      "texture_size": 2048,
      "bake_mode": "opt",
      "fp16": false
    }
  },

  "trellis_steps": null,
  "texture_size": null,
  "bake_mode": null,
  "trellis_fp16": null,
  "trellis_max_voxels": null,
  "trellis_timeout_sec": 1200,

  "blender_exe": "",
  "cors_origins": [
    "http://localhost:3000",
    "http://localhost:3001",
    "http://localhost:3002",
    "http://localhost:3003"
  ],
  "cors_origin_regex": "http://(localhost|127\\.0\\.0\\.1):\\d+",
  "output_dir": "output",
  "log_level": "INFO"
}
