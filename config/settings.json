{
  "godot_export_path": "C:/godot-project/assets/prototype/buildings",
  "trellis_path": "H:/TRELLIS",
  "trellis_model": "microsoft/TRELLIS-image-large",

  "gpu_preset": "auto",
  "_comment_fp16": "fp16 はサンプリング段のみ fp16 autocast を適用する意味 (decode は fp32 のまま)。全モデルの half 化ではない。",
  "gpu_presets": {
    "low": {
      "max_vram_gb": 10,
      "trellis_steps": 6,
      "texture_size": 512,
      "bake_mode": "fast",
      "fp16": true
    },
    "standard": {
      "max_vram_gb": 16,
      "trellis_steps": 12,
      "texture_size": 1024,
      "bake_mode": "fast",
      "fp16": true
    },
    "high": {
      "max_vram_gb": null,
      "trellis_steps": 25,
      "texture_size": 2048,
      "bake_mode": "opt",
      "fp16": false
    }
  },

  "trellis_steps": null,
  "texture_size": null,
  "bake_mode": null,
  "trellis_fp16": null,
  "trellis_timeout_sec": 3600,

  "blender_exe": "",
  "cors_origins": [
    "http://localhost:3000",
    "http://localhost:3001",
    "http://localhost:3002",
    "http://localhost:3003"
  ],
  "cors_origin_regex": "http://(localhost|127\\.0\\.0\\.1):\\d+",
  "output_dir": "output",
  "log_level": "INFO"
}
